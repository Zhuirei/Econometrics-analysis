        "#Exercise 2\n",
        "#Loading the Excel sheet Ex 2\n",
        "df = pd.read_excel('Sguera_Vincenzo.xlsx', sheet_name='Ex.2')\n",
        "\n",
        "#We convert the date\n",
        "df['obs'] = pd.to_datetime(df['obs'], dayfirst=True)\n",
        "df = df.set_index('obs')\n",
        "\n",
        "#Compute log returns using np\n",
        "returns = np.log(df / df.shift(1)).dropna()\n",
        "\n",
        "#We print the head to verify the correct format\n",
        "print(returns.head())\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "#Now we'll print the correlation matrix of returns (static interdependence)\n",
        "print(\"\\nCorrelation matrix:\")\n",
        "print(returns.corr())\n",
        "\n",
        "#Correlation of squared returns (VOLATILITY COMOVEMENT)\n",
        "print(\"\\nCorrelation matrix of squared returns (volatility dependence):\")\n",
        "print((returns**2).corr())\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "#We will show the time variation between prices\n",
        "#By using the enumerate function we are able to analyse the time varying dependence (rolling correlations)\n",
        "#We impose a window of 60 days\n",
        "window = 60\n",
        "\n",
        "pairs = [('Price1', 'Price2'),\n",
        "         ('Price1', 'Price3'),\n",
        "         ('Price2', 'Price3')]\n",
        "\n",
        "for i, (p1, p2) in enumerate(pairs):\n",
        "    rolling_corr = returns[p1].rolling(window).corr(returns[p2])\n",
        "\n",
        "    plt.figure()\n",
        "    plt.plot(rolling_corr)\n",
        "    plt.title(f\"Rolling Correlation: {p1} vs {p2}\")\n",
        "    plt.show()\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "#Now we create a GARCH model for each asset\n",
        "models = {}\n",
        "std_resid = {}\n",
        "\n",
        "for col in returns.columns:\n",
        "    model = arch_model(returns[col]*100, vol='GARCH', p=1, q=1, dist='t')\n",
        "    res = model.fit(disp='off')\n",
        "\n",
        "    models[col] = res\n",
        "    std_resid[col] = res.std_resid\n",
        "\n",
        "    #Plot conditional volatility\n",
        "    plt.figure()\n",
        "    plt.plot(res.conditional_volatility)\n",
        "    plt.title(f\"Conditional Volatility: {col}\")\n",
        "    plt.show()\n",
        "\n",
        "#We convert residuals to DataFrame\n",
        "std_resid = pd.DataFrame(std_resid)\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "#Check cross-asset dependence AFTER removing GARCH effects\n",
        "print(\"\\nCorrelation of standardized residuals:\")\n",
        "print(std_resid.corr())\n",
        "\n",
        "print(\"\\nCorrelation of squared standardized residuals (remaining volatility link):\")\n",
        "print((std_resid**2).corr())\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "#Now we will do a Ljung-Box test to analyze the residuals\n",
        "for col in std_resid.columns:\n",
        "    print(f\"\\nLjung-Box test for {col}:\")\n",
        "\n",
        "    print(acorr_ljungbox(std_resid[col], lags=[10, 20], return_df=True))\n",
        "    print(acorr_ljungbox(std_resid[col]**2, lags=[10, 20], return_df=True))\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "#Cross-correlation of squared returns (dynamic spillovers)\n",
        "from statsmodels.tsa.stattools import ccf\n",
        "\n",
        "for (p1, p2) in pairs:\n",
        "    ccf_values = ccf(returns[p1]**2, returns[p2]**2)\n",
        "\n",
        "    plt.figure()\n",
        "    plt.plot(ccf_values[:20])\n",
        "    plt.title(f\"CCF Squared Returns: {p1} vs {p2}\")\n",
        "    plt.show()\n"
