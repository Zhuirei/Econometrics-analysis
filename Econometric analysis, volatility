        "#Exercise 3\n",
        "#Importing the required packages for the analysis\n",
        "from statsmodels.tsa.api import VAR\n",
        "from statsmodels.tsa.stattools import adfuller\n",
        "\n",
        "#Load the excel file and the 3rd sheet\n",
        "df = pd.read_excel('Sguera_Vincenzo.xlsx', sheet_name='Ex.3')\n",
        "\n",
        "#Convert date and drop the first row (because of value = 0)\n",
        "df['obs'] = pd.to_datetime(df['obs'], format='%YM%m')\n",
        "df = df.set_index('obs')\n",
        "df = df.drop(df.index[0])\n",
        "\n",
        "#Checking if the format is correct\n",
        "print(df.head())\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "#Now we check the stationarity (thorugh ADF test)\n",
        "def adf_test(series, name):\n",
        "    result = adfuller(series.dropna())\n",
        "    print(f\"\\nADF Test for {name}:\")\n",
        "    print(f\"ADF statistic: {result[0]}\")\n",
        "    print(f\"p-value: {result[1]}\")\n",
        "\n",
        "for col in df.columns:\n",
        "    adf_test(df[col], col)\n",
        "\n",
        "data = df.copy()\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "#Now we may apply the VAR model estimation\n",
        "model = VAR(data)\n",
        "\n",
        "#Selecting optimal lag length\n",
        "lag_selection = model.select_order(maxlags=12)\n",
        "print(\"\\nLag selection:\")\n",
        "print(lag_selection.summary())\n",
        "\n",
        "#Choose lag\n",
        "lag = lag_selection.aic\n",
        "print(f\"\\nChosen lag: {lag}\")\n",
        "\n",
        "#Fitting VAR\n",
        "results = model.fit(lag)\n",
        "\n",
        "print(\"\\nVAR Results Summary:\")\n",
        "print(results.summary())\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "#Now we do a stability check using the integrated function in python\n",
        "print(\"\\nIs VAR stable?\")\n",
        "print(results.is_stable())\n",
        "\n",
        "#Cholesky identification (Sims approach)\n",
        "irf = results.irf(20)\n",
        "\n",
        "#Plotting IRFs\n",
        "# Oil shock → all variables\n",
        "irf.plot(orth=True)\n",
        "plt.suptitle(\"Impulse Response Functions (Orthogonalized - Cholesky)\", y=1.02)\n",
        "plt.show()\n",
        "\n",
        "# Focus specifically on oil shock propagation\n",
        "print(\"\\nIRF: Oil shock → Inflation\")\n",
        "irf.plot(orth=True, impulse='oil', response='inf')\n",
        "plt.show()\n",
        "\n",
        "print(\"\\nIRF: Oil shock → GDP growth\")\n",
        "irf.plot(orth=True, impulse='oil', response='growth')\n",
        "plt.show()\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "#Variance decomposition\n",
        "fevd = results.fevd(10)\n",
        "\n",
        "print(\"\\nForecast Error Variance Decomposition:\")\n",
        "print(fevd.summary())"
