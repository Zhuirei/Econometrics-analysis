        "#Exercise 1\n",
        "#First, we import the required packages for the analysis\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "#Then we use the google.colab package to upload the file stored locally (select the file to upload)\n",
        "from google.colab import files\n",
        "uploaded = files.upload()\n",
        "\n",
        "#Load the excel file and the 1st sheet\n",
        "df = pd.read_excel('Sguera_Vincenzo.xlsx', sheet_name='Ex.1')\n",
        "\n",
        "#Assuming the first column is time and the second one is log price, then we clean the dataset\n",
        "df.columns = ['Date', 'LogPrice']\n",
        "\n",
        "#Then we create the LogReturns and clean the dataset dropping the first row\n",
        "returns = df[\"LogPrice\"].diff().dropna()\n",
        "df = df.drop(df.index[0])\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "#Checking if the dataset is correct\n",
        "print(df)\n",
        "\n",
        "#Plotting the price for a graphical inspection\n",
        "plt.figure()\n",
        "plt.plot(df['Date'], df['LogPrice'])\n",
        "plt.title('Historical price')\n",
        "plt.show()\n",
        "\n",
        "#Then we plot only the returns\n",
        "plt.figure()\n",
        "plt.plot(df['Date'], returns)\n",
        "plt.title('Returns')\n",
        "plt.show()\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "#Now we plot the ACF of returns and squared returns\n",
        "from statsmodels.graphics.tsaplots import plot_acf\n",
        "\n",
        "plot_acf(returns, lags=40)\n",
        "plt.title(\"ACF Returns\")\n",
        "plt.show()\n",
        "\n",
        "plot_acf(returns**2, lags=40)\n",
        "plt.title(\"ACF Squared Returns\")\n",
        "plt.show()\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "#Now we will analyze the autocorrelation in the series through the Ljung-Box\n",
        "from statsmodels.stats.diagnostic import acorr_ljungbox\n",
        "\n",
        "#On returns\n",
        "lb_returns = acorr_ljungbox(returns, lags=[10], return_df=True)\n",
        "\n",
        "#On squared returns\n",
        "lb_sq = acorr_ljungbox(returns**2, lags=[10], return_df=True)\n",
        "\n",
        "print(lb_returns)\n",
        "print(lb_sq)\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "#We may also use a Jarque-Bera test in order to spot if there are fat tails\n",
        "from scipy.stats import jarque_bera\n",
        "\n",
        "jb_stat, jb_p = jarque_bera(returns)\n",
        "print(\"JB p-value:\", jb_p)\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "#We use the QQ plot to spot the distribution of observations\n",
        "import scipy.stats as stats\n",
        "\n",
        "#First we plot it against a normal distrribution\n",
        "stats.probplot(returns**2, dist=\"norm\", plot=plt)\n",
        "plt.title(\"QQ Plot - Normal\")\n",
        "plt.show()\n",
        "\n",
        "#then we plot it against a t distribution (5 degree of fredom)\n",
        "stats.probplot(returns**2, dist=\"t\", sparams=(5,), plot=plt)\n",
        "plt.title(\"QQ Plot - t (df=5)\")\n",
        "plt.show()\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "#Now we'll start to model volatility using a GARCH(1, 1) model\n",
        "from arch import arch_model\n",
        "\n",
        "#Creating the model\n",
        "model = arch_model(returns*100, vol='Garch', p=1, q=1, dist='normal')\n",
        "res = model.fit()\n",
        "\n",
        "#Printing the summary of the model\n",
        "print(res.summary())\n",
        "\n",
        "\n",
        "#Now we'll use a t-GARCH\n",
        "model_t = arch_model(returns*100, vol='Garch', p=1, q=1, dist='t')\n",
        "res_t = model_t.fit()\n",
        "\n",
        "#Printing the summary of the model\n",
        "print(res_t.summary())\n",
        "\n",
        "\n",
        "#Now we build an asymmetric GARCH model in order to capture the so-called Leverage effect\n",
        "model_gjr = arch_model(returns*100, vol='GARCH', p=1, o=1, q=1, dist='t')\n",
        "res_gjr = model_gjr.fit()\n",
        "\n",
        "#Printing the summary of the model\n",
        "print(res_gjr.summary())\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "#Plotting conditional volatility\n",
        "plt.figure()\n",
        "plt.plot(res_gjr.conditional_volatility)\n",
        "plt.title(\"Conditional Volatility (GJR-GARCH)\")\n",
        "plt.xlabel(\"Time\")\n",
        "plt.ylabel(\"Volatility\")\n",
        "plt.show()\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "#We proceed in our analysis going through the analysis of the \"Half-life\" of volatility for asymmetric GARCH\n",
        "alpha = res.params.get('alpha[1]')\n",
        "beta = res.params.get('beta[1]')\n",
        "gamma = res.params.get('gamma[1]', 0)  # default = 0 if not found\n",
        "\n",
        "persistence = alpha + beta + gamma / 2\n",
        "half_life = np.log(0.5) / np.log(persistence)\n",
        "\n",
        "#This is an approximation, it's difficult to find the true value\n",
        "print(\"Half-life:\", half_life)\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "#Then we want to analyse the residuals\n",
        "residuals = res_gjr.resid\n",
        "std_residuals = res_gjr.std_resid\n",
        "\n",
        "#We will do a Ljung Box test\n",
        "print(acorr_ljungbox(std_residuals, lags=[10, 20], return_df=True))\n",
        "print(acorr_ljungbox(std_residuals**2, lags=[10, 20], return_df=True))\n",
        "\n",
        "#Then we plot them\n",
        "plt.figure()\n",
        "plt.plot(res_gjr.std_resid)\n",
        "plt.title(\"Standardized Residuals\")\n",
        "plt.xlabel(\"Time\")\n",
        "plt.ylabel(\"Std Residuals\")\n",
        "plt.show()\n"
      ],
